generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique @db.VarChar(255)
  hashed_password String  @db.VarChar(255)
  first_name     String   @db.VarChar(100)
  last_name      String   @db.VarChar(100)
  role           String   @db.VarChar(50)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  last_active    DateTime @default(now())

  student_id     String?  @unique @db.VarChar(100)
  department     String?  @db.VarChar(100)
  class_year     String?  @db.VarChar(50)
  phone_number   String?  @db.VarChar(20)
  profile_image  String?

  quizzes_created   Quiz[]         @relation("QuizCreator")
  quiz_attempts     QuizAttempt[]  @relation("AttemptStudent")
  subjects_created  Subject[]      @relation("SubjectCreator")
  questions_created QuestionBank[] @relation("QuestionBankCreator")
  assigned_quizzes  QuizAssignment[] @relation("AssignmentStudent")
  token_block       UserTokenBlock?

  @@map("users")
}

model Quiz {
  id                   Int       @id @default(autoincrement())
  title                String    @db.VarChar(500)
  description          String?
  creator_id           Int
  subject_id           Int?
  department           String?   @db.VarChar(100)
  class_year           String?   @db.VarChar(50)
  scheduled_at         DateTime?
  duration_minutes     Int?
  grace_period_minutes Int       @default(5)
  is_live_session      Boolean   @default(false)
  live_start_time      DateTime?
  live_end_time        DateTime?
  total_marks          Float     @default(0)
  marks_per_correct    Float     @default(1)
  negative_marking     Float     @default(0)
  is_active            Boolean   @default(false)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  creator     User          @relation("QuizCreator", fields: [creator_id], references: [id])
  subject     Subject?      @relation(fields: [subject_id], references: [id])
  questions   Question[]
  attempts    QuizAttempt[]
  assignments QuizAssignment[]

  @@index([creator_id])
  @@index([subject_id])
  @@map("quizzes")
}

model Question {
  id               Int      @id @default(autoincrement())
  quiz_id          Int
  question_bank_id Int?
  question_text    String
  question_type    String   @db.VarChar(50)
  option_a         String?  @db.VarChar(500)
  option_b         String?  @db.VarChar(500)
  option_c         String?  @db.VarChar(500)
  option_d         String?  @db.VarChar(500)
  correct_answer   String   @db.VarChar(500)
  marks            Float    @default(1)
  order            Int      @default(0)

  quiz          Quiz         @relation(fields: [quiz_id], references: [id])
  question_bank QuestionBank? @relation(fields: [question_bank_id], references: [id])
  answers       Answer[]

  @@index([quiz_id])
  @@index([question_bank_id])
  @@map("questions")
}

model QuizAttempt {
  id                 Int       @id @default(autoincrement())
  quiz_id            Int
  student_id         Int
  score              Float?
  total_marks        Float
  percentage         Float?
  started_at         DateTime  @default(now())
  submitted_at       DateTime?
  time_taken_minutes Float?
  is_completed       Boolean   @default(false)
  is_graded          Boolean   @default(false)

  quiz    Quiz    @relation(fields: [quiz_id], references: [id])
  student User    @relation("AttemptStudent", fields: [student_id], references: [id])
  answers Answer[]

  @@index([quiz_id])
  @@index([student_id])
  @@map("quiz_attempts")
}

model Answer {
  id           Int      @id @default(autoincrement())
  attempt_id   Int
  question_id  Int
  answer_text  String?
  is_correct   Boolean?
  marks_awarded Float   @default(0)

  attempt  QuizAttempt @relation(fields: [attempt_id], references: [id])
  question Question    @relation(fields: [question_id], references: [id])

  @@unique([attempt_id, question_id], map: "uq_answers_attempt_question")
  @@index([attempt_id, question_id], map: "ix_answers_attempt_question")
  @@index([question_id])
  @@map("answers")
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(500)
  code        String   @unique @db.VarChar(50)
  description String?
  department  String?  @db.VarChar(100)
  creator_id  Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  creator       User           @relation("SubjectCreator", fields: [creator_id], references: [id])
  quizzes       Quiz[]
  question_bank QuestionBank[]

  @@index([creator_id])
  @@map("subjects")
}

model QuestionBank {
  id             Int      @id @default(autoincrement())
  subject_id     Int
  creator_id     Int
  question_text  String
  question_type  String   @db.VarChar(50)
  option_a       String?  @db.VarChar(500)
  option_b       String?  @db.VarChar(500)
  option_c       String?  @db.VarChar(500)
  option_d       String?  @db.VarChar(500)
  correct_answer String   @db.VarChar(500)
  topic          String?  @db.VarChar(200)
  difficulty     String   @default("medium") @db.VarChar(20)
  marks          Float    @default(1)
  times_used     Int      @default(0)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  subject        Subject    @relation(fields: [subject_id], references: [id])
  creator        User       @relation("QuestionBankCreator", fields: [creator_id], references: [id])
  quiz_questions Question[]

  @@index([subject_id])
  @@index([creator_id])
  @@map("question_bank")
}

model QuizAssignment {
  id         Int      @id @default(autoincrement())
  quiz_id    Int
  student_id Int
  assigned_at DateTime @default(now())
  attempts_allowed Int  @default(1)

  quiz    Quiz @relation(fields: [quiz_id], references: [id])
  student User @relation("AssignmentStudent", fields: [student_id], references: [id])

  @@unique([quiz_id, student_id], map: "uq_quiz_assignments_quiz_student")
  @@index([quiz_id, student_id], map: "ix_quiz_assignments_quiz_student")
  @@index([student_id])
  @@map("quiz_assignments")
}

model RevokedToken {
  id         Int       @id @default(autoincrement())
  jti        String    @unique @db.VarChar(64)
  subject    String?   @db.VarChar(255)
  revoked_at DateTime  @default(now())
  expires_at DateTime?

  @@index([subject])
  @@map("revoked_tokens")
}

model UserTokenBlock {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  revoked_before DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("user_token_blocks")
}
